# Copy this file to .env.local and fill in your key.
# Get one free at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=csk-...

# Optional: swap to OpenAI
# 1. npm install @ai-sdk/openai
# 2. Replace `cerebras('llama-3.3-70b')` with `openai('gpt-4o')` in route files
# OPENAI_API_KEY=sk-...

# Optional: swap to Anthropic
# 1. npm install @ai-sdk/anthropic
# 2. Replace `cerebras('llama-3.3-70b')` with `anthropic('claude-sonnet-4-6')` in route files
# ANTHROPIC_API_KEY=sk-ant-...
